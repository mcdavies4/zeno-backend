# ─── SERVER ───────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── WHATSAPP (Meta Cloud API) ────────────────────────
# Get these from https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_webhook_verify_token   # make this up yourself
WHATSAPP_APP_SECRET=your_app_secret                      # for signature verification

# ─── CLAUDE AI ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── BANKING PROVIDER (choose one) ───────────────────
# Option A: Modulr (recommended for UK FPS/BACS)
MODULR_API_KEY=your_modulr_api_key
MODULR_API_SECRET=your_modulr_api_secret
MODULR_BASE_URL=https://api-sandbox.modulrfinance.com   # use https://api.modulrfinance.com in prod
MODULR_ACCOUNT_ID=your_modulr_account_id

# Option B: Yapily (Open Banking — initiate payments from user's own bank)
YAPILY_APPLICATION_ID=your_yapily_app_id
YAPILY_APPLICATION_SECRET=your_yapily_app_secret

# ─── SESSION STORE ────────────────────────────────────
# For production use Redis. For testing, in-memory is fine.
REDIS_URL=redis://localhost:6379   # optional — remove to use in-memory sessions

# ─── SECURITY ─────────────────────────────────────────
ENCRYPTION_KEY=32_char_random_string_here_abc123def456  # for encrypting stored PINs
JWT_SECRET=another_random_secret_for_jwt_tokens
